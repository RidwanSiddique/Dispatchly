{
  "name": "dispatchly-backend",
  "version": "1.0.0",
  "description": "Dispatchly ITSM — Node.js / Express / PostgreSQL API",
  "main": "src/index.js",
  "engines": {
    "node": ">=26",
    "npm": ">=10"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node src/db/migrate.js up",
    "migrate:down": "node src/db/migrate.js down",
    "migrate:status": "node src/db/migrate.js status",
    "seed": "node src/db/seed.js",
    "lint": "biome lint ./src",
    "format": "biome format ./src --write",
    "check": "biome check ./src"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "nodemon": "^3.1.14"
  }
}
