PORT=3001
NODE_ENV=development

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dispatchly
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=changeme_use_a_long_random_string

# ── SMTP Email Notifications ────────────────────────────────────────────────
# Leave SMTP_HOST empty to disable email notifications (app still works).
# Gmail example: use an App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=helpdesk@yourcompany.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=Dispatchly <helpdesk@yourcompany.com>

# Base URL for "View Ticket" links inside email notifications
APP_URL=http://localhost:5173
